{
  "name": "dropbox-mcp",
  "version": "0.3.0",
  "description": "MCP server exposing Dropbox file recovery, search, download, upload, move, and delete operations to LLM agents.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "dropbox-mcp": "dist/index.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dropbox": "^10.34.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
