{
  "name": "dropbox-mcp",
  "version": "0.4.0",
  "description": "MCP server exposing Dropbox file recovery, search, download, upload, move, and delete operations to LLM agents.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dropbox-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
